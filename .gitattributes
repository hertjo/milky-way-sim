# Route baked binary data through LFS; the renderer streams these
# straight into vertex buffers, they don't render in markdown.
public/milkyway/*.bin    filter=lfs diff=lfs merge=lfs -text
public/milkyway/*.webp   filter=lfs diff=lfs merge=lfs -text
public/milkyway/*.png    filter=lfs diff=lfs merge=lfs -text
